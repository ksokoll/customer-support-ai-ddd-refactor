# ── LLM Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Models ────────────────────────────────────────────────────────────────────
LLM_MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL_NAME=text-embedding-3-small

# ── Retrieval ─────────────────────────────────────────────────────────────────
ENABLE_BLOB_RETRIEVAL=false
VECTOR_DB_PATH=data/vector_db

# ── Azure Blob (only required if ENABLE_BLOB_RETRIEVAL=true) ──────────────────
# BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
# BLOB_CONTAINER_NAME=customer-support
# KNOWLEDGE_BLOB_NAME=faq.jsonl
